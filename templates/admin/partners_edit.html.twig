{% extends 'base.html.twig' %}

{% block title %}Oxymaux - Modifier un partenaire{% endblock %}

{% block body %}

<section class=" mx-auto mt-10 px-4">
    <h1 class="text-4xl text-center mt-20 font-semibold mb-10">Modifier le partenaire</h1>
    <div class="w-full flex justify-center items-center gap-6 mx-auto max-w-7xl">
        {{ form_start(form, {'attr': {'class': 'bg-sky-100 w-full flex flex-col gap-6 p-6 rounded-lg shadow-lg'}}) }}
            <div class="flex w-full gap-6">
                {{ form_label(form.name, 'Nom du partenaire', {'label_attr': {'class': 'w-1/3'}}) }}
                {{ form_widget(form.name, {'attr': {'class': 'w-2/3 px-4 py-2 bg-white border border-sky-500 rounded'}}) }}
            </div>
            <div class="flex w-full gap-6 items-start">
                {{ form_label(form.logo, 'Logo du partenaire', {
                    'label_attr': {'class': 'w-1/3'}
                }) }}

                <div class="w-2/3 flex flex-col gap-4" data-controller="file-upload">

                    {% if partner.logo %}
                        <img
                            src="{{ asset('images/' ~ partner.logo) }}"
                            alt="{{ partner.name }}"
                            class="w-48 rounded shadow"
                        >
                        <p class="text-sm text-gray-600">Image actuelle : {{ partner.logo }}</p>
                        <p class="text-sm text-gray-600">Pour changer l'image, sélectionner un nouveau fichier ci-dessous.</p>
                    {% endif %}

                    <label
                        for="{{ form.logo.vars.id }}"
                        class="inline-flex items-center justify-center px-4 py-2 bg-sky-500 text-white rounded cursor-pointer hover:bg-sky-600 transition w-fit"
                    >
                        Sélectionner une image
                    </label>

                    {{ form_widget(form.logo, {
                        'attr': {
                            'class': 'hidden',
                            'data-file-upload-target': 'input',
                            'data-action': 'change->file-upload#updateFilename'
                        }
                    }) }}

                    <span
                        data-file-upload-target="filename"
                        class="text-sm text-gray-600"
                    >
                        Aucun fichier sélectionné
                    </span>

                </div>
            </div>
            <div class="flex w-full gap-6">
                {{ form_label(form.job, 'Métier du partenaire', {'label_attr': {'class': 'w-1/3'}}) }}
                {{ form_widget(form.job, {'attr': {'class': 'w-2/3 px-4 py-2 bg-white border border-sky-500 rounded'}}) }}
            </div>
            <div class="flex w-full gap-6">
                {{ form_label(form.description, 'Description du partenaire', {'label_attr': {'class': 'w-1/3'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'w-2/3 px-4 py-2 bg-white border border-sky-500 rounded'}}) }}
            </div>
            <div data-controller="confirm" class="flex justify-center gap-4">
                <a href="{{ path('app_home') }}" class="px-4 py-2 bg-gray-300 text-gray-700 rounded hover:bg-gray-400 transition cursor-pointer">Annuler</a>
                <button type="submit" class="px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600 transition cursor-pointer">Enregistrer les modifications</button>
                <button type="button" data-action="click->confirm#openModal" class="px-4 py-2 bg-red-500 text-white rounded hover:bg-red-600 transition cursor-pointer ml-2">Supprimer le partenaire</button>
                <div class="hidden fixed inset-0 flex items-center justify-center z-50" data-confirm-target="modal">
                    <div class="bg-white p-6 rounded-lg shadow-lg shadow-sky-500">
                        <p class="mb-4">Êtes-vous sûr de vouloir supprimer ce partenaire ?</p>
                        <p class="mb-4 text-center"><strong>{{ partner.name }}</strong></p>
                        <div class="flex justify-center gap-4">
                            <a href="{{ path('app_partners_delete', {'id': partner.id}) }}" class="px-4 py-2 bg-red-500 text-white rounded hover:bg-red-600 transition">Oui, supprimer</a>
                            <button type="button" data-action="click->confirm#cancel" class="px-4 py-2 bg-gray-300 text-gray-700 rounded hover:bg-gray-400 transition cursor-pointer">Non, annuler</button>
                        </div>
                    </div>
                </div> 
            </div>
        {{ form_end(form) }}
    </div>
</section>
{% endblock %}