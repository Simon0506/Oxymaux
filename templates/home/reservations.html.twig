{% extends 'base.html.twig' %}

{% block title %}Oxymaux - Historique des réservations{% endblock %}

{% block body %}
<section class="mx-auto mt-10 px-4">
    <h1 class="text-4xl text-center mt-20 font-semibold">Mes réservations</h1>
    <div class="w-full flex flex-col items-center gap-2 mx-auto max-w-2xl">
        <h2 class="text-2xl font-semibold mt-6">Activités à venir</h2>
        {% if activitiesUpcoming|length > 0 %}
            {% for activity in activitiesUpcoming %}
                {% if not activity.canceled %}
                    <div class="w-full bg-sky-100 p-6 rounded-lg shadow-lg flex flex-col md:flex-row items-center gap-4">
                        <div class="flex-1 flex flex-col gap-2">
                            <p class="font-semibold text-lg">{{ activity.service.name }}</p>
                            <p class="text-gray-700 mb-4">{{ activity.fullDate }}</p>
                            {% for reservation in reservations %}
                                {% if reservation.activity.id == activity.id %}
                                    <div data-controller="confirm" class="flex items-center gap-2">
                                        {% if reservation.status == 'validée' or reservation.status == 'en attente' %}
                                            <button data-action="click->confirm#openModal" class="px-2 py-1 bg-white hover:bg-red-700 text-red-500 border border-red-500 text-sm rounded transition w-fit cursor-pointer" title="Annuler la réservation">
                                                <i class="fa-solid fa-xmark"></i>
                                            </button>
                                            <div class="hidden fixed inset-0 flex items-center justify-center z-50" data-confirm-target="modal">
                                                <form class="bg-white p-6 rounded-lg shadow-lg shadow-sky-500" method="post" action="{{ path('app_reservation_user_cancel', {'id': reservation.id}) }}">
                                                    <p class="mb-4">Êtes-vous sûr de vouloir annuler cette inscription ?</p>
                                                    <label for="reason" class="block text-sm font-medium text-gray-700 mb-2">Raison de l'annulation (optionnel) :</label>
                                                    <textarea id="reason" name="reason" rows="3" class="w-full border border-gray-300 rounded px-2 py-1 text-sm mb-4" placeholder="Merci d'indiquer la raison de l'annulation..."></textarea>
                                                    <div class="flex justify-center gap-4">
                                                        <button type="button" data-action="click->confirm#cancel" class="px-4 py-2 bg-gray-300 rounded-lg cursor-pointer">Non, conserver</button>
                                                        <button type="submit" class="px-4 py-2 bg-red-500 text-white rounded-lg cursor-pointer">Oui, annuler</button>
                                                    </div>
                                                </form>
                                            </div>
                                        {% endif %}
                                        <span class="font-semibold">{{ reservation.dog.name }}</span>
                                        {% if reservation.status == 'validée' %}
                                            <span class="text-green-500 font-normal">Réservation validée <i class="fa-solid fa-check"></i></span>
                                        {% elseif reservation.status == 'refusée' %}
                                            <span class="text-red-500 font-normal">Réservation refusée <i class="fa-solid fa-times"></i></span>
                                        {% elseif reservation.status == 'en attente' %}
                                            <span class="text-blue-500 font-normal">Réservation en attente <i class="fa-solid fa-hourglass-half"></i></span>
                                        {% elseif reservation.status == 'annulée' %}
                                            <span class="text-red-500 font-normal">Réservation annulée <i class="fa-solid fa-times"></i></span>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                        <div class="flex flex-col items-center gap-2 w-full md:w-1/4">
                            <img src="{{ asset('images/' ~ activity.service.image) }}" alt="{{ activity.service.name }}" class="w-full rounded shadow-lg object-cover">
                            <a href="{{ path('app_activity', {'id': activity.id}) }}" class="px-2 py-1 bg-[#7a96a1] text-white text-sm text-shadow-md text-shadow-black rounded hover:bg-[#5a6b7a] transition w-fit">Voir les détails</a>
                        </div>
                    </div>
                {% else %}
                    <div class="w-full bg-red-100 p-6 rounded-lg shadow-lg flex flex-col md:flex-row items-center gap-4">
                        <div class="flex-1 flex flex-col gap-2">
                            <p class="font-semibold text-lg">{{ activity.service.name }} <span class="text-red-500">(Activité annulée)</span></p>
                            <p class="text-gray-700">{{ activity.fullDate }}</p>
                        </div>
                        <img src="{{ asset('images/' ~ activity.service.image) }}" alt="{{ activity.service.name }}" class="w-full md:w-1/4 rounded shadow-lg object-cover">
                    </div>
                {% endif %}
            {% endfor %}
        {% else %}
            <p class="text-center text-gray-700">Vous n'avez aucune activité à venir pour le moment.</p>
        {% endif %}
        <h2 class="text-2xl font-semibold mt-6">Activités passées</h2>
        {% if activitiesPast|length > 0 %}
            {% for activity in activitiesPast %}
                <div class="w-full bg-sky-100 p-4 rounded shadow-lg flex flex-col md:flex-row items-center gap-2">
                    <div class="flex-1 flex flex-col">
                        <p class="font-semibold text-lg">{{ activity.service.name }}</p>
                        <p class="text-gray-700 mb-4">{{ activity.fullDate }}</p>
                        {% for reservation in reservations %}
                            {% if reservation.activity.id == activity.id %}
                                <p data-controller="auto-cancel" class="font-semibold">{{ reservation.dog.name }} -
                                {% if reservation.status == 'validée' %}
                                        <span class="text-green-500 font-normal">Réservation validée <i class="fa-solid fa-check"></i></span>
                                {% elseif reservation.status == 'refusée' %}
                                    <span class="text-red-500 font-normal">Réservation refusée <i class="fa-solid fa-times"></i></span>
                                {% elseif reservation.status == 'en attente' %}
                                    <span data-auto-cancel-target="pending" data-auto-cancel-reservation-id="{{ reservation.id }}" class="text-blue-500 font-normal">Réservation en attente <i class="fa-solid fa-hourglass-half"></i></span>
                                {% elseif reservation.status == 'annulée' %}
                                    <span class="text-red-500 font-normal">Réservation annulée <i class="fa-solid fa-times"></i></span>
                                {% endif %}
                                </p>
                            {% endif %}
                        {% endfor %}
                        
                    </div>
                    <div class="flex flex-col items-center gap-2 w-full md:w-1/4">
                        {% if activity.service.image %}
                            <img src="{{ asset('images/' ~ activity.service.image) }}" alt="{{ activity.service.name }}" class="w-full rounded shadow-lg object-cover">
                        {% endif %}
                        <a href="{{ path('app_activity', {'id': activity.id}) }}" class="px-2 py-1 bg-[#7a96a1] text-white text-sm text-shadow-md text-shadow-black rounded hover:bg-[#5a6b7a] transition w-fit">Voir l'activité</a>
                    </div>
                </div>
            {% endfor %}
        {% else %}
            <p class="text-center text-gray-700">Vous n'avez aucune activité passée pour le moment.</p>
        {% endif %}
    </div>
</section>
{% endblock %}