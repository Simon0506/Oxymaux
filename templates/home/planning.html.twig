{% extends 'base.html.twig' %}

{% block title %}Oxymaux - Mon planning{% endblock %}

{% block body %}

<section class=" mx-auto mt-10 px-4">
    <h1 class="text-4xl text-center mt-20">Mon planning</h1>
    <div class="mt-10 max-w-4xl mx-auto">
        <p class="text-lg text-center font-extralight">
            Mon planning est en cours de construction. N'hésitez pas à me contacter pour plus d'informations ou pour réserver une séance.
        </p>
        <div class="mt-6 flex justify-center">
            <a href="{{ path('app_contact') }}" class="inline-block px-6 py-3 bg-sky-300 text-white text-shadow-xs text-shadow-black rounded-full shadow-md hover:bg-sky-400 transition duration-300">Me contacter <i class="fa-solid fa-envelope"></i></a>
        </div>
    </div>
</section>
{% endblock %}