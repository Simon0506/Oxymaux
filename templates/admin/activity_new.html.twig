{% extends 'base.html.twig' %}

{% block title %}Oxymaux - Ajouter une activité{% endblock %}

{% block body %}

<section class=" mx-auto mt-10 px-4">
    <h1 class="text-4xl text-center mt-20 font-semibold mb-10">Ajouter une nouvelle activité</h1>
    <div class="w-full flex justify-center items-center gap-6 mx-auto max-w-4xl">
        {{ form_start(form, {'attr': {'class': 'bg-sky-100 w-full flex flex-col gap-6 p-6 rounded-lg shadow-lg', 'data-controller': 'activity-form'}}) }}
            <div class="flex w-full gap-6">
                {{ form_label(form.service, 'Nom de l\'activité', {'label_attr': {'class': 'w-1/3'}}) }}
                {{ form_widget(form.service, {'attr': {'class': 'w-2/3 px-4 py-2 bg-white border border-sky-500 rounded'}}) }}
            </div>
            <div class="flex w-full gap-6">
                {{ form_label(form.date, 'Date de l\'activité', {'label_attr': {'class': 'w-1/3'}}) }}
                {{ form_widget(form.date, {'attr': {'class': 'bg-white w-2/3 px-4 py-2 border border-sky-500 rounded'}}) }}
            </div>
            <div class="flex w-full gap-6">
                {{ form_label(form.start, 'Heure de début', {'label_attr': {'class': 'w-1/3'}}) }}
                {{ form_widget(form.start, {'attr': {'class': 'bg-white w-2/3 px-4 py-2 border border-sky-500 rounded'}}) }}
            </div>
            <div class="flex w-full gap-6">
                {{ form_label(form.end, 'Heure de fin', {'label_attr': {'class': 'w-1/3'}}) }}
                {{ form_widget(form.end, {'attr': {'class': 'bg-white w-2/3 px-4 py-2 border border-sky-500 rounded'}}) }}
            </div>
            <div class="flex w-full gap-6">
                {{ form_label(form.nbPlaces, 'Nombre de places', {'label_attr': {'class': 'w-1/3'}}) }}
                {{ form_widget(form.nbPlaces, {'attr': {'class': 'bg-white w-2/3 px-4 py-2 border border-sky-500 rounded', 'data-activity-form-target': 'nbPlaces'}}) }}
            </div>
            <div class="flex w-full gap-6">
                {{ form_label(form.comment, 'Commentaire', {'label_attr': {'class': 'w-1/3'}}) }}
                {{ form_widget(form.comment, {'attr': {'class': 'bg-white w-2/3 px-4 py-2 border border-sky-500 rounded'}}) }}
            </div>
            <div class="flex items-center justify-start w-full gap-6">
                {{ form_label(form.openToAll, 'Ouvert à tous', {'label_attr': {'class': 'w-1/3'}}) }}
                {{ form_widget(form.openToAll, {'attr': {'class': 'bg-white border border-sky-500 rounded', 'data-activity-form-target': 'openToAll', 'data-action': 'activity-form#toggle'}}) }}
            </div>
            <div class="flex justify-center gap-4">
                <a href="{{ path('app_reservations_admin', {'date': date|date('Y-m-d')}) }}" class="px-4 py-2 bg-gray-300 text-gray-700 rounded hover:bg-gray-400 transition cursor-pointer">Annuler</a>
                <button type="submit" class="px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600 transition cursor-pointer">Enregistrer l'activité</button>
            </div>
        {{ form_end(form) }}
    </div>
</section>
{% endblock %}