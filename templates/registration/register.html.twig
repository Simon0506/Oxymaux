{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
    <section class="max-w-2xl w-full mx-auto mt-10 px-4">
    {% for flash_error in app.flashes('verify_email_error') %}
        <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}

        <h1 class="text-4xl text-center mt-20 font-semibold">S'inscrire</h1>

        {{ form_errors(registrationForm) }}

        {{ form_start(registrationForm, {'attr': {'class': 'bg-sky-100 p-4 rounded-xl space-y-4 mt-10 flex flex-col items-center w-full'}}) }}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 w-full">
                <div class="flex flex-col gap-2">
                    {{ form_label(registrationForm.lastName, 'Nom') }}
                    {{ form_widget(registrationForm.lastName, {'attr': {'class': 'bg-white border border-sky-500 rounded w-full'}}) }}
                </div>
                <div class="flex flex-col gap-2">
                    {{ form_label(registrationForm.firstName, 'Prénom') }}
                    {{ form_widget(registrationForm.firstName, {'attr': {'class': 'bg-white border border-sky-500 rounded w-full'}}) }}
                </div>
                <div class="flex flex-col gap-2">
                    {{ form_label(registrationForm.address, 'Adresse') }}
                    {{ form_widget(registrationForm.address, {'attr': {'class': 'bg-white border border-sky-500 rounded w-full'}}) }}
                </div>
                <div class="flex flex-col gap-2">
                    {{ form_label(registrationForm.postalCode, 'Code postal') }}
                    {{ form_widget(registrationForm.postalCode, {'attr': {'class': 'bg-white border border-sky-500 rounded w-full'}}) }}
                </div>
                <div class="flex flex-col gap-2">             
                    {{ form_label(registrationForm.city, 'Ville') }}
                    {{ form_widget(registrationForm.city, {'attr': {'class': 'bg-white border border-sky-500 rounded w-full'}}) }}  
                </div>
                <div class="flex flex-col gap-2">
                    {{ form_label(registrationForm.phone, 'Téléphone') }}
                    {{ form_widget(registrationForm.phone, {'attr': {'class': 'bg-white border border-sky-500 rounded w-full'}}) }}
                </div>
                <div class="flex flex-col gap-2">
                    {{ form_label(registrationForm.email, 'Email') }}
                    {{ form_widget(registrationForm.email, {'attr': {'class': 'bg-white border border-sky-500 rounded w-full'}}) }}
                </div>
                <div class="flex flex-col gap-2">
                    {{ form_label(registrationForm.plainPassword, 'Mot de passe') }}
                    {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'bg-white border border-sky-500 rounded w-full'}}) }}
                </div>
            </div>
            <div class="flex items-center gap-2">
                {{ form_row(registrationForm.agreeTerms, {'label': false}) }}
                <span class="text-sm">J'affirme avoir lu et accepté les termes et conditions de notre <a href="{{ path('app_politique_confidentialite') }}" class="text-blue-500 hover:underline">politique de confidentialité</a>.</span>
            </div>

            <button type="submit" class="bg-sky-500 text-white py-2 px-4 rounded hover:bg-sky-600 cursor-pointer">S'inscrire</button>
        {{ form_end(registrationForm) }}
    </section>
{% endblock %}
