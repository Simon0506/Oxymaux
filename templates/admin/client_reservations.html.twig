{% extends 'base.html.twig' %}

{% block title %}Réservations du client{% endblock %}

{% block body %}
<section class="max-w-7xl mx-auto mt-10 px-4" data-controller="filter-activity">
    <a href="{{ path('app_clients') }}" class="text-gray-600 hover:text-gray-800 transition duration-300">
        <i class="fa-solid fa-arrow-left"></i> Revenir à la liste des clients
    </a>
    <h1 class="text-3xl text-center font-bold mb-6 mt-2">Réservations de {{ client.firstname }} {{ client.lastname }}</h1>

    <div class="flex flex-col items-center w-full gap-6 max-w-4xl mx-auto">
        {% if reservations is empty %}
            <p class="text-gray-500 italic">Aucune réservation trouvée pour ce client.</p>
        {% else %}
            
            <div class="w-full flex flex-col sm:flex-row items-center justify-between gap-4 bg-gray-50 p-4 rounded-lg border border-gray-200 shadow-sm">
                
                <div class="flex items-center gap-2 w-full sm:w-auto">
                    <label for="service-filter" class="text-sm font-medium text-gray-700 whitespace-nowrap">Service :</label>
                    <select 
                        id="service-filter" 
                        data-filter-activity-target="serviceSelect"
                        data-action="change->filter-activity#filter" 
                        class="w-full sm:w-auto px-3 py-1.5 bg-white border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-sky-400 font-normal text-gray-700"
                    >
                        <option value="all">Tous les services</option>
                        {% set uniqueServices = [] %}
                        {% for activity in activities %}
                            {% if activity.service.name not in uniqueServices %}
                                {% set uniqueServices = uniqueServices|merge([activity.service.name]) %}
                                <option value="{{ activity.service.name|lower }}">{{ activity.service.name }}</option>
                            {% endif %}
                        {% endfor %}
                    </select>
                </div>

                <div class="flex items-center gap-2 w-full sm:w-auto">
                    <label for="date-filter" class="text-sm font-medium text-gray-700 whitespace-nowrap">Date :</label>
                    <input 
                        type="date" 
                        id="date-filter" 
                        data-filter-activity-target="dateInput"
                        data-action="input->filter-activity#filter" 
                        class="w-full sm:w-auto px-3 py-1 bg-white border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-sky-400 font-normal text-gray-700"
                    >
                    <button 
                        type="button" 
                        data-action="click->filter-activity#clearDate" 
                        class="text-xs text-gray-400 hover:text-red-500 transition"
                        title="Effacer la date"
                    >
                        <i class="fa-solid fa-circle-xmark text-base"></i>
                    </button>
                </div>
            </div>

            {% for activity in activities %}
                <div 
                    data-filter-activity-target="card" 
                    data-service="{{ activity.service.name|lower }}"
                    data-date="{{ activity.date|date('Y-m-d') }}"
                    class="bg-sky-100 p-4 rounded-lg shadow-md w-full flex justify-between items-center h-fit transition-all duration-300"
                >
                    <div>
                        <h2 class="text-xl font-semibold mb-2">{{ activity.service.name }} - {{ activity.fullDate }}</h2>
                        <div class="text-gray-700"><strong>Chien(s) :</strong>
                            <ul class="list-disc list-inside mt-1 pl-1">
                            {% for reservation in reservations %}
                                {% if reservation.activity.id == activity.id %}
                                    <li>{{ reservation.dog.fullName }}</li>
                                {% endif %}
                            {% endfor %}
                            </ul>
                        </div>
                    </div>
                    {% if activity.service.image %}
                        <img src="{{ asset('images/' ~ activity.service.image) }}" alt="{{ activity.service.name }}" class="hidden md:block w-1/4 h-32 object-cover rounded-lg ml-4">
                    {% endif %}
                </div>
            {% endfor %}
        {% endif %}
    </div>
</section>
{% endblock %}