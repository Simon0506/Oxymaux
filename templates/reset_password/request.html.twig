{% extends 'base.html.twig' %}

{% block title %}Réinitialiser le mot de passe{% endblock %}

{% block body %}
<section class="max-w-2xl w-full mx-auto mt-10 px-4">
    {% for flash_error in app.flashes('reset_password_error') %}
        <div class="text-red-500 bg-red-100 text-sm p-2 rounded w-full">{{ flash_error }}</div>
    {% endfor %}
    <h1 class="text-4xl text-center mt-20 mb-10 font-semibold">Réinitialiser le mot de passe</h1>
    <p class="text-center text-gray-700 text-sm">
            Entrez votre adresse e-mail, et nous vous enverrons un
            lien pour réinitialiser votre mot de passe.
    </p>

    {{ form_start(requestForm, {'attr': {'class': 'bg-sky-100 p-4 rounded-xl space-y-4 mt-10 flex flex-col items-center w-full'}}) }}
        <div class="flex items-center gap-4 w-full">
            {{ form_label(requestForm.email, 'Adresse e-mail', {'label_attr': {'class': 'w-1/3'}}) }}
            {{ form_widget(requestForm.email, {'attr': {'class': 'bg-white border border-sky-500 rounded w-2/3', 'autocomplete': 'email'}}) }}
            {{ form_errors(requestForm.email) }}
        </div>

        <button type="submit" class="bg-sky-500 text-white px-4 py-2 rounded cursor-pointer hover:bg-sky-600">Envoyer le lien de réinitialisation</button>
    {{ form_end(requestForm) }}
</section>
{% endblock %}
