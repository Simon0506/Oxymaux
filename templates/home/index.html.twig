{% extends 'base.html.twig' %}

{% block title %}Oxymaux Médiation Animale{% endblock %}

{% block body %}
<section class=" mx-auto mt-10 px-4">
    <div class="flex flex-col md:flex-row justify-around items-center w-full">
        <div class="flex flex-col items-center w-full md:w-1/2">
            <h1 class="text-6xl text-center mt-20">
                <p>Bienvenue chez</p>
                <p class="mt-2"><span class="text-sky-300 text-shadow-md text-shadow-black">OXY</span>MAUX</p>
            </h1>
            <p class="text-3xl text-sky-300 text-center mt-10">
                Un souffle d'oxygène grâce aux animaux !
            </p>
            <div class="flex justify-center items-center mt-10">
                <a href="{{ path('app_services') }}" class="px-6 py-3 bg-sky-300 text-white text-shadow-xs text-shadow-black text-xl rounded-full shadow-md hover:bg-sky-400 transition duration-300 text-center">Découvrir mes services <i class="fa-solid fa-paw"></i></a>
                <a href="{{ path('app_contact') }}" class="ml-4 px-6 py-3 bg-orange-300 text-white text-shadow-xs text-shadow-black text-xl rounded-full shadow-md hover:bg-orange-400 transition duration-300 text-center">Me contacter <i class="fa-solid fa-envelope"></i></a>
            </div>
        </div>
        <div class="mt-10 w-full md:w-1/2 flex justify-center mr-0 md:mr-20">
            <img src="{{ asset('images/relation_chien_humain.jpg') }}" alt="Image d'accueil" class="w-full max-w-4xl max-h-96 object-cover rounded-lg shadow-lg">
        </div>
    </div>
    <div class="flex flex-col md:flex-row justify-center items-center gap-10 w-full mt-10">
        <div class="p-4 w-full max-w-2xl">
            <h2 class="text-4xl text-center mb-10">A propos</h2>
            <div class="bg-orange-100 bg-opacity-80 rounded-lg shadow-lg flex flex-col md:flex-row justify-center items-center gap-4 mb-10 p-4">
                <img src="{{ asset('images/logo2.jpeg') }}" alt="A propos de moi" class="w-48 h-48 object-cover rounded-full shadow-lg">
                <div class="p-6 flex flex-col items-center">
                    <p class="text-lg text-center max-w-3xl mx-auto font-extralight md:ml-6">
                        Je suis Noémie, passionnée par les animaux et leur bien-être. J'ai créé Oxymaux pour offrir des services personnalisés, destinés à améliorer l'estime de soi et le bien-être des individus grâce aux animaux.
                    </p>
                    <a href="{{ path('app_parcours') }}" class="mt-4 inline-block mx-auto text-center px-4 py-2 bg-sky-300 text-white text-shadow-xs text-shadow-black rounded-full shadow-md hover:bg-sky-400 transition duration-300">Découvrir mon parcours <i class="fa-solid fa-paw"></i></a>
                </div>
            </div>
        </div>
        <div class="p-4 w-full max-w-4xl">
            <h2 class="text-4xl text-center mb-10">Mes services</h2>
            <div class="grid grid-cols-[repeat(auto-fit,minmax(300px,1fr))] gap-5">
                <div class="bg-sky-100 bg-opacity-80 rounded-lg shadow-lg py-6 flex flex-col items-center">
                    <h3 class="text-xl text-center mb-4 underline underline-offset-4"><i class="fa-solid fa-dog"></i><span class="ml-4">Education canine</span></h3>
                    <p class="font-extralight text-center">Apprendre les bases, renforcer l'obéissance et la complicité.</p>
                </div>
                <div class="bg-lime-100 bg-opacity-80 rounded-lg shadow-lg py-6 flex flex-col items-center">
                    <h3 class="text-xl text-center mb-4 underline underline-offset-4"><i class="fa-solid fa-hand-holding-heart"></i><span class="ml-4">Médiation animale</span></h3>
                    <p class="font-extralight text-center">Améliorer le bien-être grâce à la présence apaisante des animaux.</p>
                </div>
                <div class="bg-red-100 bg-opacity-80 rounded-lg shadow-lg py-6 flex flex-col items-center">
                    <h3 class="text-xl text-center mb-4 underline underline-offset-4"><i class="fa-solid fa-chalkboard-teacher"></i><span class="ml-4">Ateliers thématiques</span></h3>
                    <p class="font-extralight text-center">Ateliers sur la communication animale, le comportement et les soins.</p>
                </div>
                <div class="bg-indigo-100 bg-opacity-80 rounded-lg shadow-lg py-6 flex flex-col items-center">
                    <h3 class="text-xl text-center mb-4 underline underline-offset-4"><i class="fa-solid fa-user-check"></i><span class="ml-4">Consultations personnalisées</span></h3>
                    <p class="font-extralight text-center">Solutions sur mesure pour les besoins spécifiques de votre animal.</p>
                </div>
            </div>
            <div class="flex justify-center mt-6">
                <a href="{{ path('app_services') }}" class="inline-block mx-auto text-center px-6 py-3 bg-sky-300 text-white text-shadow-xs text-shadow-black rounded-full shadow-md hover:bg-sky-400 transition duration-300">Voir tous mes services <i class="fa-solid fa-paw"></i></a>
            </div>
        </div>
    </div>
    <div class="mt-20 px-4">
        <h2 class="text-4xl text-center mb-10">Besoin d'une prestation ou d'un devis ?</h2>
        <div class="flex justify-center mt-6">
            <a href="{{ path('app_contact') }}" class="inline-block mx-auto text-center px-6 py-3 bg-orange-300 text-2xl text-white text-shadow-xs text-shadow-black rounded-full shadow-md hover:bg-orange-400 transition duration-300">Contactez-moi !</a>
        </div>
    </div>
</section>
{% endblock %}
