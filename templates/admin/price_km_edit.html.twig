{% extends 'base.html.twig' %}

{% block title %}Oxymaux - Modifier les frais de déplacement{% endblock %}

{% block body %}
<section class=" mx-auto mt-10 px-4">
    <h1 class="text-4xl text-center mt-20 font-semibold mb-10">Modifier les frais de déplacement</h1>
    <div class="w-full flex justify-center items-center gap-6 mx-auto max-w-lg">
    {{ form_start(form, {'attr': {'class': 'bg-sky-100 w-full flex flex-col gap-6 p-6 rounded-lg shadow-lg'}}) }}
        <div class="flex w-full gap-6 justify-start items-center bg-white p-4 rounded-lg border border-gray-300 shadow">
            {{ form_label(form.minLength, 'Distance min', {'label_attr': {'class': 'w-1/2'}}) }}
            {{ form_widget(form.minLength, {'attr': {'class': 'w-1/2 border border-sky-300 rounded'}}) }}
        </div>
        <div class="flex w-full gap-6 justify-start items-center bg-white p-4 rounded-lg border border-gray-300 shadow">
            {{ form_label(form.maxLength, 'Distance max', {'label_attr': {'class': 'w-1/2'}}) }}
            {{ form_widget(form.maxLength, {'attr': {'class': 'w-1/2 border border-sky-300 rounded'}}) }}
        </div>
        <div class="flex w-full gap-6 justify-start items-center bg-white p-4 rounded-lg border border-gray-300 shadow">
            {{ form_label(form.price, 'Prix', {'label_attr': {'class': 'w-1/2'}}) }}
            {{ form_widget(form.price, {'attr': {'class': 'w-1/2 border border-sky-300 rounded'}}) }}
        </div>
        <div class="flex justify-center gap-4 mt-6">
            <a href="{{ path('app_services') }}" class="px-4 py-2 bg-gray-300 text-gray-700 rounded hover:bg-gray-400 transition cursor-pointer">Annuler</a>
            <button type="submit" class="px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600 transition cursor-pointer">Enregistrer</button>
        </div>
    {{ form_end(form) }}
    </div>
</section>
{% endblock %}