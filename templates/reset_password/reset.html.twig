{% extends 'base.html.twig' %}

{% block title %}Réinitialisation du mot de passe{% endblock %}

{% block body %}
<section class="max-w-2xl w-full mx-auto mt-10 px-4">
    {% for flash_error in app.flashes('reset_password_error') %}
        <div class="text-red-500 bg-red-100 text-sm p-2 rounded w-full">{{ flash_error }}</div>
    {% endfor %}
    <h1 class="text-4xl text-center mt-20 mb-10 font-semibold">Réinitialisation du mot de passe</h1>

    {{ form_start(resetForm, {'attr': {'class': 'bg-sky-100 p-4 rounded-xl space-y-4 mt-10 flex flex-col items-center w-full'}}) }}
        {% if resetForm.plainPassword.first.vars.errors|length > 0 %}
            <div class="text-red-500 bg-red-100 text-sm p-2 rounded w-full">
                {{ form_errors(resetForm.plainPassword.first) }}
            </div>
        {% endif %}
        <div data-controller="password-visibility" class="flex items-center gap-4 w-full">
            {{ form_label(resetForm.plainPassword.first, 'Nouveau mot de passe', {'label_attr': {'class': 'w-1/4'}}) }}
            <div class="relative w-3/4">
                {{ form_widget(resetForm.plainPassword.first, {
                    attr: {
                        class: 'w-full bg-white px-2 py-1 pr-10 rounded border-gray-300 shadow-sm',
                        'data-password-visibility-target': 'input'
                    }
                }) }}

                <button type="button" data-action="click->password-visibility#toggle" class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-500 hover:text-gray-700 focus:outline-none cursor-pointer">
                    <i class="fa-solid fa-eye"></i>
                </button>
            </div>
        </div>
        <div data-controller="password-visibility" class="flex items-center gap-4 w-full">
            {{ form_label(resetForm.plainPassword.second, 'Confirmer le nouveau mot de passe', {'label_attr': {'class': 'w-1/4'}}) }}
            <div class="relative w-3/4">
                {{ form_widget(resetForm.plainPassword.second, {
                    attr: {
                        class: 'w-full bg-white px-2 py-1 pr-10 rounded border-gray-300 shadow-sm',
                        'data-password-visibility-target': 'input'
                    }
                }) }}

                <button type="button" data-action="click->password-visibility#toggle" class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-500 hover:text-gray-700 focus:outline-none cursor-pointer">
                    <i class="fa-solid fa-eye"></i>
                </button>
            </div>
        </div>
        <button type="submit" class="bg-sky-500 text-white px-4 py-2 rounded cursor-pointer hover:bg-sky-600">Réinitialiser le mot de passe</button>
    {{ form_end(resetForm) }}
</section>
{% endblock %}
