{% extends 'base.html.twig' %}

{% block title %}Oxymaux - Ajouter un partenaire{% endblock %}

{% block body %}

<section class=" mx-auto mt-10 px-4">
    <h1 class="text-4xl text-center mt-20 font-semibold mb-10">Ajouter un nouveau partenaire</h1>
    <div class="w-full flex justify-center items-center gap-6 mx-auto max-w-7xl">
        {{ form_start(form, {'attr': {'class': 'bg-sky-100 w-full flex flex-col gap-6 p-6 rounded-lg shadow-lg'}}) }}
            <div class="flex w-full gap-6">
                {{ form_label(form.name, 'Nom du partenaire', {'label_attr': {'class': 'w-1/3'}}) }}
                {{ form_widget(form.name, {'attr': {'class': 'w-2/3 px-4 py-2 bg-white border border-sky-500 rounded'}}) }}
            </div>
            <div class="flex w-full gap-6 items-start">
                {{ form_label(form.logo, 'Logo du partenaire', {
                    'label_attr': {'class': 'w-1/3'}
                }) }}

                <div class="w-2/3 flex flex-col gap-4" data-controller="file-upload">

                    <label
                        for="{{ form.logo.vars.id }}"
                        class="inline-flex items-center justify-center px-4 py-2 bg-sky-500 text-white rounded cursor-pointer hover:bg-sky-600 transition w-fit"
                    >
                        Sélectionner une image
                    </label>

                    {{ form_widget(form.logo, {
                        'attr': {
                            'class': 'hidden',
                            'data-file-upload-target': 'input',
                            'data-action': 'change->file-upload#updateFilename'
                        }
                    }) }}

                    <span
                        data-file-upload-target="filename"
                        class="text-sm text-gray-600"
                    >
                        Aucun fichier sélectionné
                    </span>

                </div>
            </div>
            <div class="flex w-full gap-6">
                {{ form_label(form.job, 'Métier du partenaire', {'label_attr': {'class': 'w-1/3'}}) }}
                {{ form_widget(form.job, {'attr': {'class': 'w-2/3 px-4 py-2 bg-white border border-sky-500 rounded'}}) }}
            </div>
            <div class="flex w-full gap-6">
                {{ form_label(form.description, 'Description du partenaire', {'label_attr': {'class': 'w-1/3'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'w-2/3 px-4 py-2 bg-white border border-sky-500 rounded'}}) }}
            </div>
            <div class="flex justify-center gap-4">
                <a href="{{ path('app_home') }}" class="px-4 py-2 bg-gray-300 text-gray-700 rounded hover:bg-gray-400 transition cursor-pointer">Annuler</a>
                <button type="submit" class="px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600 transition cursor-pointer">Enregistrer le partenaire</button>
            </div>
        {{ form_end(form) }}
    </div>
</section>
{% endblock %}