{% extends 'base.html.twig' %}

{% block title %}Oxymaux - Contact{% endblock %}

{% block body %}

<section class=" mx-auto mt-10 px-4">
    <h1 class="text-4xl text-center mt-20 font-semibold">Contact</h1>
    <div class="flex flex-col md:grid md:grid-cols-2 items-center gap-10 mt-10 w-full h-auto">
        <div class="w-full max-w-64 mx-auto flex flex-col gap-4 h-full justify-around">
            <div class="flex flex-col gap-4">
                <h2 class="text-2xl font-semibold text-center">Mes coordonnées</h2>
                <ul class="gap-4 flex flex-col items-center">
                    <li><i class="fa-solid fa-envelope"></i> <a href="mailto:{{ admin.email }}" class="hover:text-sky-500">{{ admin.email }}</a></li>
                    <li><i class="fa-solid fa-phone"></i> {{ admin.phone }}</li>
                </ul>
            </div>
            <div class="h-px w-1/2 my-4 mx-auto border-t border-sky-300"></div>
            <div class="flex flex-col gap-4">
                <h2 class="text-2xl font-semibold text-center">Mes réseaux sociaux</h2>
                <p class="text-center">Retrouvez-moi également sur Facebook et Instagram</p>
                <ul class="flex gap-6 justify-center">
                    <li><a href="https://www.facebook.com/p/Oxymaux-100080042719436/" target="_blank" class="hover:text-blue-700 transition" title="Facebook"><i class="fa-brands fa-facebook fa-2x"></i></a></li>
                    <li><a href="https://www.instagram.com/oxymaux_17/" target="_blank" class="hover:text-pink-500 transition" title="Instagram"><i class="fa-brands fa-instagram fa-2x"></i></a></li>
                </ul>
            </div>
        </div>
        <div class="h-px w-1/2 md:hidden mx-auto border-t border-sky-300"></div>
        <div class="max-w-2xl w-full">
            <h2 class="text-2xl font-semibold mb-4 text-center">Formulaire de contact</h2>
            <form data-controller="send" data-action="submit->send#submit" action="{{ path('app_contact') }}" method="POST" class="bg-sky-100 p-6 rounded-lg shadow-lg">
                <div class="flex flex-col gap-6">
                    <div class="flex flex-col md:flex-row gap-6 w-full">
                        <div class="w-full md:w-1/2">
                            <label for="name" class="block text-sm font-medium text-gray-700">Votre nom</label>
                            <input type="text" name="name" id="name" required class="mt-1 block w-full px-4 py-2 bg-white border border-sky-500 rounded focus:outline-none focus:ring-sky-300 focus:border-sky-300">
                        </div>
                        <div class="w-full md:w-1/2">
                            <label for="email" class="block text-sm font-medium text-gray-700">Votre adresse e-mail</label>
                            <input type="email" name="email" id="email" required class="mt-1 block w-full px-4 py-2 bg-white border border-sky-500 rounded focus:outline-none focus:ring-sky-300 focus:border-sky-300">
                        </div>
                    </div>
                    <div>
                        <label for="subject" class="block text-sm font-medium text-gray-700">Sujet de votre message</label>
                        <select name="subject" id="subject" required class="mt-1 block w-full px-4 py-2 bg-white border border-sky-500 rounded focus:outline-none focus:ring-sky-300 focus:border-sky-300">
                            <option value="" selected>Choisissez un sujet</option>
                            <option value="general">Demande générale</option>
                            <option value="devis">Devis</option>
                            <option value="autre">Autre question</option>
                        </select>
                    </div>
                    <div>
                        <label for="message" class="block text-sm font-medium text-gray-700">Votre message</label>
                        <textarea name="message" id="message" rows="5" required class="mt-1 block w-full px-4 py-2 bg-white border border-sky-500 rounded focus:outline-none focus:ring-sky-300 focus:border-sky-300"></textarea>
                    </div>
                    <div class="flex justify-center">
                        <button type="submit" class="px-4 py-2 bg-sky-300 rounded-full hover:bg-sky-400 transition cursor-pointer">Envoyer <i class="fa-solid fa-paper-plane"></i></button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>
{% endblock %}