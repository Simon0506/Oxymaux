{% extends 'base.html.twig' %}

{% block title %}Oxymaux - Réservation{% endblock %}

{% block body %}
<section class="max-w-7xl mx-auto mt-10 px-4">
    <a href="{{ path('app_activity', {'id': activity.id}) }}" class="text-gray-600 hover:text-gray-800 transition duration-300">
        <i class="fa-solid fa-arrow-left"></i> Revenir à l'activité
    </a>
    
    <h1 class="text-4xl text-center mt-20 font-semibold">
        <span>{{ activity.service.name }} du {{ activity.fullDate }}</span>
    </h1>
    
    <div data-controller="reservation" class="w-full flex justify-center items-center gap-6 mx-auto max-w-4xl mt-10">
        {{ form_start(form, {'attr': {'class': 'bg-sky-100 w-full flex flex-col gap-6 p-6 rounded-lg shadow-lg'}}) }}
            
            <div data-reservation-target="dog" class="flex flex-col w-full gap-3">
                <div class="flex w-full gap-6 items-center">
                    {{ form_label(form.dog, 'Participant', {'label_attr': {'class': 'w-1/3 font-semibold'}}) }}
                    
                    <div class="w-2/3 flex flex-col gap-2">
                        <div class="relative w-full">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                                <i class="fa-solid fa-magnifying-glass text-sm"></i>
                            </span>
                            <input 
                                type="text" 
                                data-action="input->reservation#filterDogs" 
                                placeholder="Rechercher un chien, une race, un maître..." 
                                class="w-full pl-9 pr-4 py-1.5 bg-white text-sm border border-sky-300 rounded focus:outline-none focus:ring-2 focus:ring-sky-500 font-normal"
                            >
                        </div>
                        
                        {{ form_widget(form.dog, {'attr': {
                            'data-reservation-target': 'dogSelect',
                            'class': 'w-full px-4 py-2 bg-white border border-sky-500 rounded',
                        }}) }}
                    </div>
                </div>
            </div>
            
            <div data-reservation-target="name" class="hidden flex w-full gap-6 items-center">
                {{ form_label(form.name, 'Participant alternatif', {'label_attr': {'class': 'w-1/3 font-semibold'}}) }}
                {{ form_widget(form.name, {'attr': {'class': 'bg-white w-2/3 px-4 py-2 border border-sky-500 rounded', 'disabled': 'disabled'}}) }}
            </div>
            
            <div class="flex w-fit mx-auto">
                <button type="button" data-reservation-target="toggleButton" data-action="click->reservation#toggleName" class="px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600 transition cursor-pointer text-sm font-normal">Entrer un nom manuellement</button>
            </div>
            
            <hr class="border-sky-200 my-2">
            
            <div class="flex justify-center gap-4">
                <a href="{{ path('app_reservations_admin', {'date': activity.date|date('Y-m-d')}) }}" class="px-4 py-2 bg-gray-300 text-gray-700 rounded hover:bg-gray-400 transition cursor-pointer">Annuler</a>
                <button type="submit" class="px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600 transition cursor-pointer">Enregistrer l'inscription</button>
            </div>
        {{ form_end(form) }}
    </div>
</section>
{% endblock %}