{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<section class="max-w-2xl w-full mx-auto mt-10 px-4">
    <form method="post">
        {% if error %}
            <div class="text-red-500 bg-red-100 p-2 rounded w-full">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        {% if app.user %}
            <div class="mb-3">
                Vous êtes connecté en tant que {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Se déconnecter</a>
            </div>
        {% endif %}

        <h1 class="text-4xl text-center mt-20 mb-10 font-semibold">Se connecter</h1>
        <div class="bg-sky-100 p-4 rounded-xl space-y-4 mt-10 flex flex-col items-center w-full">
            <div class="flex items-center gap-4 w-full">
                <label for="username" class="w-1/3">Email</label>
                <input type="email" value="{{ last_username }}" name="_username" id="username" class="bg-white border border-sky-500 rounded w-2/3" autocomplete="email" required autofocus>
            </div>
            <div class="flex items-center gap-4 w-full">
                <label for="password" class="w-1/3">Mot de passe</label>
                <input type="password" name="_password" id="password" class="bg-white border border-sky-500 rounded w-2/3" autocomplete="current-password" required>
            </div>
            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

            <div class="checkbox mb-3">
                <input type="checkbox" name="_remember_me" id="_remember_me">
                <label for="_remember_me">Se souvenir de moi</label>
            </div>

            <button class="bg-sky-300 py-2 px-4 rounded-full hover:bg-sky-400 cursor-pointer" type="submit">
                Se connecter
            </button>
            <div class="mt-4 flex flex-col items-center gap-4 text-sm">
                <span>Mot de passe oublié ? <a href="{{ path('app_forgot_password_request') }}" class="text-blue-500 hover:underline transition">Réinitialiser</a></span>
                <span>Pas encore de compte ? <a href="{{ path('app_register') }}" class="text-blue-500 hover:underline transition">S'inscrire</a></span>
            </div>
        </div>
    </form>
</section>
{% endblock %}
